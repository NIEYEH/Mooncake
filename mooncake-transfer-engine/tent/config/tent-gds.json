{
  "verbose": true,

  "enable_runtime_queue": true,

  "runtime_queue": {
    "max_outstanding_owners": 64,
    "max_outstanding_bytes": 268435456,

    "max_dispatch_owners": 20,
    "max_dispatch_bytes": 67108864,
    "max_dispatch_read_owners": 16,
    "max_dispatch_write_owners": 4,

    "max_waiting_owners": 4096,
    "max_waiting_bytes": 8589934592,

    "staging_owner_reserve": 0,
    "staging_byte_reserve": 0,

    "progress_fallback_interval_us": 1000
  },

  "transports": {
    "tcp": {
      "enable": true
    },

    "rdma": {
      "enable": false
    },

    "gds": {
      "enable": true,
      "read_worker_threads": 16,
      "write_worker_threads": 4,
      "max_inflight_reads": 16,
      "max_inflight_writes": 4,
      "submit_retry_count": 0,
      "write_starvation_timeout_us": 100000,
      "adaptive_concurrency": true,
      "adaptive_sample_window": 128,
      "adaptive_evaluation_interval": 32,
      "adaptive_recovery_windows": 3,
      "adaptive_min_read_inflight": 4,
      "adaptive_min_write_inflight": 1,
      "adaptive_p99_degradation_ratio": 1.25,
      "adaptive_p99_recovery_ratio": 1.05,
      "adaptive_read_p99_target_us": 60000,
      "adaptive_write_p99_target_us": 10000
    },

    "io_uring": {
      "enable": false
    },

    "shm": {
      "enable": false
    },

    "nvlink": {
      "enable": false
    },

    "mnnvl": {
      "enable": false
    }
  }
}
