{
  "verbose": true,

  "enable_runtime_queue": true,

  "runtime_queue": {
    "max_outstanding_owners": 1024,
    "max_outstanding_bytes": 2147483648,

    "max_dispatch_owners": 128,
    "max_dispatch_bytes": 536870912,

    "staging_owner_reserve": 0,
    "staging_byte_reserve": 0,

    "progress_fallback_interval_us": 200
  },

  "transports": {
    "tcp": {
      "enable": true
    },

    "rdma": {
      "enable": false
    },

    "gds": {
      "enable": true,
      "io_batch_depth": 64,
      "max_inflight_batches": 1,
      "allow_concurrent_batches": false,
      "read_batch_depth": 64,
      "write_batch_depth": 32,
      "max_read_batch_bytes": 268435456,
      "max_write_batch_bytes": 67108864,
      "enable_batch_read": false,
      "enable_batch_write": false,
      "read_worker_threads": 8,
      "write_worker_threads": 8,
      "max_inflight_reads": 32,
      "max_inflight_writes": 32,
      "aggregation_delay_us": 50,
      "status_poll_interval_us": 50,
      "submit_retry_count": 1,
      "max_status_poll_errors": 20
    },

    "io_uring": {
      "enable": false
    },

    "shm": {
      "enable": false
    },

    "nvlink": {
      "enable": false
    },

    "mnnvl": {
      "enable": false
    }
  }
}
